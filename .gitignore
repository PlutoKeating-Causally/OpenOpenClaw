# ===========================================
# OpenOpenClaw Project - Git Ignore Rules
# ===========================================

# --------------------
# Project Generated Data (Critical)
# --------------------
data/
test_data/
static/
exports/
uploads/
temp/
tmp/
*.zip
*.db
*.sqlite
*.log
backend/data/
frontend/dist/

# --------------------
# Python
# --------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/venv/
backend/__pycache__/
venv/
env/
.venv/
pip-log.txt
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ipynb_checkpoints/

# --------------------
# Node.js / Frontend
# --------------------
node_modules/
frontend/node_modules/
dist/
dist-ssr/
npm-debug.log*
yarn-debug.log*
.pnpm-store/
.cache/
.vite/
*.local

# --------------------
# IDEs & System
# --------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# --------------------
# Docker
# --------------------
.docker/
docker-compose.override.yml

# --------------------
# Environment Files
# --------------------
.env
.env.*
*.env
! .env.example
